        <mxCell id="Wh9XW5Wj_-NFwADT-OHS-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;h2 data-section-id=&quot;19imvf9&quot; data-start=&quot;95&quot; data-end=&quot;132&quot;&gt;So sánh 2 cách thiết kế ADDRESS&lt;/h2&gt;&lt;br/&gt;&lt;div class=&quot;TyagGW_tableContainer&quot;&gt;&lt;div tabindex=&quot;-1&quot; class=&quot;group TyagGW_tableWrapper flex flex-col-reverse w-fit&quot;&gt;&lt;table data-start=&quot;134&quot; data-end=&quot;905&quot; class=&quot;w-fit min-w-(--thread-content-width)&quot;&gt;&lt;thead data-start=&quot;134&quot; data-end=&quot;233&quot;&gt;&lt;tr data-start=&quot;134&quot; data-end=&quot;233&quot;&gt;&lt;th data-start=&quot;134&quot; data-end=&quot;145&quot; data-col-size=&quot;sm&quot; class=&quot;&quot;&gt;Tiêu chí&lt;/th&gt;&lt;th data-start=&quot;145&quot; data-end=&quot;194&quot; data-col-size=&quot;md&quot; class=&quot;&quot;&gt;Cách 1: Thuộc tính phức hợp (gắn vào STUDENTS)&lt;/th&gt;&lt;th data-start=&quot;194&quot; data-end=&quot;233&quot; data-col-size=&quot;md&quot; class=&quot;&quot;&gt;Cách 2: Tách thành thực thể ADDRESS&lt;/th&gt;&lt;/tr&gt;&lt;/thead&gt;&lt;tbody data-start=&quot;333&quot; data-end=&quot;905&quot;&gt;&lt;tr data-start=&quot;333&quot; data-end=&quot;455&quot;&gt;&lt;td data-start=&quot;333&quot; data-end=&quot;356&quot; data-col-size=&quot;sm&quot;&gt;&lt;strong data-start=&quot;335&quot; data-end=&quot;355&quot;&gt;Độ dễ khi vẽ ERD&lt;/strong&gt;&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;356&quot; data-end=&quot;413&quot;&gt;Dễ, nhanh, ít thành phần (chỉ cần thêm thuộc tính con)&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;413&quot; data-end=&quot;455&quot;&gt;Phức tạp hơn (thêm thực thể + quan hệ)&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;456&quot; data-end=&quot;551&quot;&gt;&lt;td data-start=&quot;456&quot; data-end=&quot;478&quot; data-col-size=&quot;sm&quot;&gt;&lt;strong data-start=&quot;458&quot; data-end=&quot;477&quot;&gt;Tổ chức dữ liệu&lt;/strong&gt;&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;478&quot; data-end=&quot;513&quot;&gt;Dữ liệu nằm chung trong STUDENTS&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;513&quot; data-end=&quot;551&quot;&gt;Dữ liệu được chuẩn hóa, tách riêng&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;552&quot; data-end=&quot;677&quot;&gt;&lt;td data-start=&quot;552&quot; data-end=&quot;577&quot; data-col-size=&quot;sm&quot;&gt;&lt;strong data-start=&quot;554&quot; data-end=&quot;576&quot;&gt;Tìm kiếm theo Quận&lt;/strong&gt;&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;577&quot; data-end=&quot;625&quot;&gt;Có thể tìm được (vì có thuộc tính Quận riêng)&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;625&quot; data-end=&quot;677&quot;&gt;Tìm rất dễ, rõ ràng, có thể tối ưu query tốt hơn&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;678&quot; data-end=&quot;813&quot;&gt;&lt;td data-start=&quot;678&quot; data-end=&quot;719&quot; data-col-size=&quot;sm&quot;&gt;&lt;strong data-start=&quot;680&quot; data-end=&quot;718&quot;&gt;Mở rộng (nhiều địa chỉ / thay đổi)&lt;/strong&gt;&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;719&quot; data-end=&quot;764&quot;&gt;Khó mở rộng (mỗi student chỉ có 1 địa chỉ)&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;764&quot; data-end=&quot;813&quot;&gt;Linh hoạt (1 student có thể có nhiều địa chỉ)&lt;/td&gt;&lt;/tr&gt;&lt;tr data-start=&quot;814&quot; data-end=&quot;905&quot;&gt;&lt;td data-start=&quot;814&quot; data-end=&quot;842&quot; data-col-size=&quot;sm&quot;&gt;&lt;strong data-start=&quot;816&quot; data-end=&quot;841&quot;&gt;Phù hợp bài toán ship&lt;/strong&gt;&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;842&quot; data-end=&quot;859&quot;&gt;Đủ dùng cơ bản&lt;/td&gt;&lt;td data-col-size=&quot;md&quot; data-start=&quot;859&quot; data-end=&quot;905&quo